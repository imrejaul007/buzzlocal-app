{
  "expo": {
    "name": "BuzzLocal",
    "slug": "buzzlocal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "buzzlocal",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rez.buzzlocal",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BuzzLocal needs your location to show nearby events, places, and local content.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "BuzzLocal uses your location to send you alerts about nearby events and activities."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.rez.buzzlocal",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow BuzzLocal to use your location to show nearby content."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
